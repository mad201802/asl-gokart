{
    "name": "headunit",
    "productName": "headunit",
    "version": "0.4.15",
    "description": "ASL GoKart headunit package made with react, electron, electron-forge, shadcn-ui, vite and typescript",
    "main": ".vite/build/main.js",
    "scripts": {
        "start": "electron-forge start",
        "package": "electron-forge package",
        "make": "electron-forge make",
        "make:pi4": "DEBUG=electron-packager electron-forge make --arch=arm64",
        "make:odroid": "electron-forge make --arch=armv7l",
        "publish": "electron-forge publish",
        "prett": "prettier . --write",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:unit": "jest",
        "test:e2e": "playwright test",
        "test:all": "jest && playwright test",
        "clean": "rimraf .vite dist out"
    },
